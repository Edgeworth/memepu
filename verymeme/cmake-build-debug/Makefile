# target to generate assembly for a file
src/verymeme/parser.cpp.s:
	$(MAKE) -f CMakeFiles/memecad.dir/build.make CMakeFiles/memecad.dir/src/verymeme/parser.cpp.s
	$(MAKE) -f CMakeFiles/memesim.dir/build.make CMakeFiles/memesim.dir/src/verymeme/parser.cpp.s
	$(MAKE) -f CMakeFiles/memeroute.dir/build.make CMakeFiles/memeroute.dir/src/verymeme/parser.cpp.s
	$(MAKE) -f CMakeFiles/tests.dir/build.make CMakeFiles/tests.dir/src/verymeme/parser.cpp.s
	$(MAKE) -f CMakeFiles/memeware.dir/build.make CMakeFiles/memeware.dir/src/verymeme/parser.cpp.s
.PHONY : src/verymeme/parser.cpp.s

